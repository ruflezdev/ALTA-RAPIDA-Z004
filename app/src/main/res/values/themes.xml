<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.AltaRapida" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_variant</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Color for UI elements -->
        <item name="colorError">@color/error</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.AltaRapida" parent="Base.Theme.AltaRapida" />

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>
